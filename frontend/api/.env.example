# ─────────────────────────────────────────────
# Required — copy to .env and fill in values
# ─────────────────────────────────────────────

# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-secure-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000

# Supabase (server-to-server, use service role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@aivora.ai

# Redis (for distributed rate-limiting)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AI=10/minute
